<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!--
        Wrap Magento\Catalog\Block\Product\Image::toHtml so we can swap
        the rendered <img> for a <picture> + WebP source. See the plugin
        class docblock for the full transformation.
    -->
    <type name="Magento\Catalog\Block\Product\Image">
        <plugin name="etechflow_io_picture_block"
                type="ETechFlow\ImageOptimizer\Plugin\Catalog\Block\PictureBlockPlugin"
                sortOrder="100"/>
    </type>

    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="etechflow_io_optimize"
                      xsi:type="object">ETechFlow\ImageOptimizer\Console\Command\OptimizeCommand</item>
                <item name="etechflow_io_verify"
                      xsi:type="object">ETechFlow\ImageOptimizer\Console\Command\VerifyCommand</item>
            </argument>
        </arguments>
    </type>

    <!--
        Admin grid data source — binds the listing UI Component XML to
        our OptimizationLog collection. Same pattern as BISN's grid.
    -->
    <virtualType name="ETechFlowIoLogGridFilterPool"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\FilterPool">
        <arguments>
            <argument name="appliers" xsi:type="array">
                <item name="regular" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\RegularFilter</item>
                <item name="fulltext" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\FulltextFilter</item>
            </argument>
        </arguments>
    </virtualType>

    <virtualType name="ETechFlowIoLogGridDataProvider"
                 type="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
        <arguments>
            <argument name="collection"
                      xsi:type="object" shared="false">ETechFlow\ImageOptimizer\Model\ResourceModel\OptimizationLog\Collection</argument>
            <argument name="filterPool"
                      xsi:type="object" shared="false">ETechFlowIoLogGridFilterPool</argument>
        </arguments>
    </virtualType>

    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="etechflow_io_log_listing_data_source"
                      xsi:type="string">ETechFlow\ImageOptimizer\Model\ResourceModel\OptimizationLog\Collection</item>
            </argument>
        </arguments>
    </type>
</config>
